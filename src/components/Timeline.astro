---
import { CAREER } from '../consts';

interface Props {
  // 'horizontal' for the home strip, 'vertical' for the about page.
  variant?: 'horizontal' | 'vertical';
}
const { variant = 'vertical' } = Astro.props;
---

{
  variant === 'horizontal' ? (
    <ul class="flex gap-4 overflow-x-auto pb-2 -mx-5 px-5">
      {CAREER.map((e) => (
        <li class="min-w-56 shrink-0 bg-surface border border-border rounded-xl p-4">
          <p class="font-mono text-xs text-coral">{e.period}</p>
          <p class="font-medium mt-2">{e.role}</p>
          <p class="text-muted text-sm">{e.company}</p>
        </li>
      ))}
    </ul>
  ) : (
    <ol class="border-l border-border pl-6 space-y-8">
      {CAREER.map((e) => (
        <li class="relative">
          <span class="absolute -left-[1.6rem] top-1.5 w-2.5 h-2.5 rounded-full bg-coral" />
          <p class="font-mono text-xs text-muted">{e.period}</p>
          <p class="font-display text-lg mt-1">
            {e.role} <span class="text-muted font-sans text-base">· {e.company}</span>
          </p>
          <p class="text-muted text-sm mt-1">{e.highlight}</p>
        </li>
      ))}
    </ol>
  )
}
