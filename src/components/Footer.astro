---
import { SITE } from '../consts';

const year = new Date().getFullYear();
const links = [
  { label: 'Email', href: `mailto:${SITE.email}` },
  { label: 'GitHub', href: SITE.github },
  { label: 'LinkedIn', href: SITE.linkedin },
];
---

<footer class="border-t border-border mt-24">
  <div class="max-w-4xl mx-auto px-5 py-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <div class="font-mono text-xs text-muted">
      © {year} {SITE.name} · Built with Astro
    </div>
    <ul class="flex items-center gap-5 text-sm">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="text-muted transition-colors hover:text-coral">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
