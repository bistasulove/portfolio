---
import Tag from './Tag.astro';
import { href } from '../consts';

interface Props {
  slug: string;
  title: string;
  pitch: string;
  tech: string[];
}
const { slug, title, pitch, tech } = Astro.props;
---

<a
  href={href(`/work/${slug}`)}
  class="group block bg-surface border border-border rounded-xl p-5 transition-colors hover:border-coral"
>
  <h3 class="font-display text-xl group-hover:text-coral transition-colors">{title}</h3>
  <p class="text-muted text-sm mt-2">{pitch}</p>
  <ul class="flex flex-wrap gap-2 mt-4">
    {tech.map((t) => <li><Tag label={t} /></li>)}
  </ul>
</a>
