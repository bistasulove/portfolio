---
interface Props {
  publishDate: Date;
  readingTime?: number;
}
const { publishDate, readingTime } = Astro.props;

const dateStr = publishDate.toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<p class="font-mono text-xs text-muted">
  <time datetime={publishDate.toISOString()}>{dateStr}</time>
  {readingTime && <span> · {readingTime} min read</span>}
</p>
