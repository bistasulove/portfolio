---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostMeta from '../../components/PostMeta.astro';
import Tag from '../../components/Tag.astro';
import Giscus from '../../components/Giscus.astro';
import { SITE, href } from '../../consts';

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts', (p) => !p.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(post);
const { title, description, publishDate, tags } = post.data;

// Reading time injected by the remark plugin at render time.
const readingTime = remarkPluginFrontmatter.minutesRead as number | undefined;

// Build a table of contents from h2/h3 headings.
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const ogImage = href(`/og/posts/${post.id}.png`);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: publishDate.toISOString(),
  keywords: tags.join(', '),
  image: new URL(ogImage, Astro.site).href,
  url: new URL(href(`/writing/${post.id}`), Astro.site).href,
  author: { '@type': 'Person', name: SITE.name },
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} jsonLd={articleSchema}>
  <article class="max-w-2xl mx-auto px-5 py-16">
    <a href={href('/writing')} class="font-mono text-xs text-muted hover:text-coral">← Writing</a>

    <h1 class="font-display text-4xl mt-4 leading-tight">{title}</h1>
    <div class="mt-4">
      <PostMeta publishDate={publishDate} readingTime={readingTime} />
    </div>
    <ul class="flex flex-wrap gap-2 mt-4">
      {tags.map((t) => <li><Tag label={t} /></li>)}
    </ul>

    {
      toc.length > 1 && (
        <nav class="mt-8 bg-surface border border-border rounded-xl p-5">
          <p class="font-mono text-xs text-muted uppercase tracking-wide">Contents</p>
          <ul class="mt-3 space-y-1.5 text-sm">
            {toc.map((h) => (
              <li class={h.depth === 3 ? 'ml-4' : ''}>
                <a href={`#${h.slug}`} class="text-muted hover:text-coral transition-colors">
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <div class="prose max-w-none mt-10 border-t border-border pt-10">
      <Content />
    </div>

    <Giscus />
  </article>
</BaseLayout>
