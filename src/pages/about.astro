---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import { SITE, href } from '../consts';

const values = [
  'Boring, reliable systems beat clever, fragile ones.',
  'Write the code the next engineer can read at 2am.',
  'Ship, measure, then optimise — in that order.',
  'Own the problem end to end, not just the ticket.',
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  jobTitle: SITE.role,
  email: `mailto:${SITE.email}`,
  url: new URL(href('/about'), Astro.site).href,
  sameAs: [SITE.github, SITE.linkedin],
  address: { '@type': 'PostalAddress', addressLocality: SITE.location },
};
---

<BaseLayout
  title="About"
  description={`About ${SITE.name} — career journey, values, and what I'm looking for.`}
  jsonLd={personSchema}
>
  <article class="max-w-2xl mx-auto px-5 py-16">
    <h1 class="font-display text-4xl">About</h1>

    {/* Intro — warm, personal, not a resume summary */}
    <div class="prose-custom mt-6 space-y-4 text-primary leading-relaxed">
      <p>
        I'm {SITE.name}, a software engineer in {SITE.location}. I like the unglamorous parts of
        the job — the system that quietly handles peak traffic at 2am, the onboarding flow that
        stops being a support ticket, the alert that fires before a customer notices. Most of my
        career has been about owning a hard problem end to end, and being the person other teams
        escalate to when it matters.
      </p>
      <p>
        I grew up in Nepal and went to India for my engineering degree, then spent my early career
        in Bangalore building fintech and SaaS products — improving OCR pipelines and shipping
        payment services at Fyle, then leading backend work back home in Lalitpur. For the last
        several years I owned a payments-and-compliance module at Paylocity, holding it to 99.99%
        reliability as it grew. Along the way I've shipped things solo too: a municipal tax SaaS in
        Nepal and a privacy-first browser toolkit. Now I'm in Brisbane, looking for the next team
        to do that kind of work with.
      </p>
    </div>

    <h2 class="font-display text-2xl mt-12">Journey</h2>
    <div class="mt-6">
      <Timeline variant="vertical" />
    </div>

    <h2 class="font-display text-2xl mt-12">How I work</h2>
    <ul class="mt-6 space-y-3">
      {
        values.map((v) => (
          <li class="flex gap-3">
            <span class="text-coral mt-1">—</span>
            <span class="text-primary">{v}</span>
          </li>
        ))
      }
    </ul>

    <h2 class="font-display text-2xl mt-12">Right now</h2>
    <p class="text-muted mt-4">
      I'm based in Brisbane with full working rights in Australia, and open to senior backend or
      full-stack roles — ideally a team that cares about reliability and lets engineers own real
      problems end to end. I'm happy working remotely or on-site. Reach me at
      <a href={`mailto:${SITE.email}`} class="text-coral hover:underline">{SITE.email}</a>
      or see <a href={href('/resume')} class="text-coral hover:underline">my resume</a>.
    </p>
  </article>
</BaseLayout>
