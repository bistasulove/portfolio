---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import { SITE, href } from '../consts';

// TODO: replace with real values/working-style statements.
const values = [
  'Boring, reliable systems beat clever, fragile ones.',
  'Write the code the next engineer can read at 2am.',
  'Ship, measure, then optimise — in that order.',
  'Own the problem end to end, not just the ticket.',
];
---

<BaseLayout title="About" description={`About ${SITE.name} — career journey, values, and what I'm looking for.`}>
  <article class="max-w-2xl mx-auto px-5 py-16">
    <h1 class="font-display text-4xl">About</h1>

    {/* Intro — warm, personal, not a resume summary */}
    <div class="prose-custom mt-6 space-y-4 text-primary leading-relaxed">
      <p>
        {/* TODO: 1–2 paragraph personal intro. Who you are beyond the job title. */}
        I'm {SITE.name}, a backend engineer based in {SITE.location}. TODO: a couple of warm,
        human sentences about who you are and what you care about.
      </p>
      <p>
        {/* TODO: career journey narrative — Nepal → Australia, why engineering, what drives you */}
        TODO: the story of how you got here — what pulled you into engineering and what keeps
        you in it.
      </p>
    </div>

    {/* Optional photo — strongly recommended to humanise the page */}
    {/* TODO: add <Image /> of yourself here once available */}

    <h2 class="font-display text-2xl mt-12">Journey</h2>
    <div class="mt-6">
      <Timeline variant="vertical" />
    </div>

    <h2 class="font-display text-2xl mt-12">How I work</h2>
    <ul class="mt-6 space-y-3">
      {
        values.map((v) => (
          <li class="flex gap-3">
            <span class="text-coral mt-1">—</span>
            <span class="text-primary">{v}</span>
          </li>
        ))
      }
    </ul>

    <h2 class="font-display text-2xl mt-12">Right now</h2>
    <p class="text-muted mt-4">
      {SITE.status}. {/* TODO: what kind of role/team/problem you're looking for */}
      Reach me at
      <a href={`mailto:${SITE.email}`} class="text-coral hover:underline">{SITE.email}</a>
      or see <a href={href('/resume')} class="text-coral hover:underline">my resume</a>.
    </p>
  </article>
</BaseLayout>
