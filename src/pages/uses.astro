---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  {
    title: 'Editor & AI',
    items: [
      'VS Code and PyCharm — my main editors',
      'Cursor — trying it out for AI-assisted editing',
      'Claude Code — used extensively, day to day',
      'Gemini CLI — experimenting with it',
    ],
  },
  {
    title: 'Terminal & utilities',
    items: [
      'iTerm2',
      'zsh with oh-my-zsh and Powerlevel10k',
      'Flycut — clipboard manager',
      'espanso — text expansion and shortcuts',
    ],
  },
  {
    title: 'Languages & tools',
    items: [
      'Python, Django, and Pytest — my core backend stack',
      'PostgreSQL and Docker',
      'React and Next.js — as I expand into frontend',
      'Astro — what this site is built with',
      'Bruno — my API client (switched from Postman)',
    ],
  },
  {
    title: 'Hardware',
    items: [
      'MacBook Pro (M3 Pro)',
      'Keychron K2 — when I’m not on the laptop keyboard',
      'Any decent external monitor — no strong preference',
    ],
  },
];
---

<BaseLayout title="Uses" description="The tools, hardware, and setup I use day to day.">
  <article class="max-w-2xl mx-auto px-5 py-16">
    <h1 class="font-display text-4xl">Uses</h1>
    <p class="text-muted mt-3">The tools and setup I reach for every day.</p>

    <div class="mt-10 space-y-8">
      {
        sections.map((section) => (
          <section>
            <h2 class="font-display text-xl border-b border-border pb-2">{section.title}</h2>
            <ul class="list-disc list-outside ml-5 mt-4 space-y-1 text-primary">
              {section.items.map((item) => <li>{item}</li>)}
            </ul>
          </section>
        ))
      }
    </div>
  </article>
</BaseLayout>
