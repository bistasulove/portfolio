---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, TECH_TAGS } from '../consts';
---

<BaseLayout>
  <section class="max-w-4xl mx-auto px-5 py-20">
    <p class="font-mono text-sm text-coral">// {SITE.location} · {SITE.status}</p>
    <h1 class="font-display text-5xl sm:text-6xl mt-4 leading-tight">
      I build backends that don't break.
    </h1>
    <p class="text-lg text-muted max-w-2xl mt-6">
      {SITE.role} with 7+ years shipping reliable systems — from solo end-to-end SaaS
      to multi-tenant platforms. {/* TODO: refine subheading */}
    </p>
    <ul class="flex flex-wrap gap-2 mt-6 font-mono text-xs">
      {
        TECH_TAGS.map((t) => (
          <li class="bg-coral-tint text-coral rounded-md px-2 py-0.5">{t}</li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
