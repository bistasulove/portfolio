---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tag from '../components/Tag.astro';
import { SITE, CAREER, EDUCATION, PROJECTS, href } from '../consts';

const skills = {
  Languages: ['Python', 'JavaScript', 'TypeScript', 'SQL'],
  Backend: [
    'Django REST Framework',
    'Flask',
    'FastAPI',
    'Celery',
    'Pytest',
    'Microservices',
    'Multi-Tenancy',
  ],
  Frontend: ['React', 'Next.js', 'Tailwind', 'HTML5', 'CSS'],
  'Data & Storage': ['PostgreSQL', 'Redis', 'ElasticSearch', 'Kafka', 'RabbitMQ'],
  'Cloud & DevOps': ['AWS', 'Docker', 'Heroku', 'GitHub Actions', 'CI/CD', 'Linux'],
  Observability: ['Datadog', 'Sentry', 'Metabase', 'Retool', 'Fullstory'],
  Security: ['OAuth 2.0', 'JWT', '2FA/MFA', 'RBAC', 'Auth0'],
};
---

<BaseLayout title="Resume" description={`Resume of ${SITE.name}, ${SITE.role}.`}>
  <article class="max-w-2xl mx-auto px-5 py-16">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="font-display text-4xl">{SITE.name}</h1>
        <p class="text-muted mt-1">{SITE.role} · {SITE.location}</p>
        <p class="font-mono text-xs text-muted mt-2 flex flex-wrap gap-x-2 gap-y-1">
          <a href={`mailto:${SITE.email}`} class="hover:text-coral">{SITE.email}</a> ·
          <a href={SITE.github} class="hover:text-coral">GitHub</a> ·
          <a href={SITE.linkedin} class="hover:text-coral">LinkedIn</a>
        </p>
      </div>
      <a
        href={href('/resume.pdf')}
        download
        class="shrink-0 bg-coral hover:bg-coral-deep text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors"
      >
        Download PDF
      </a>
    </div>

    <section class="mt-10">
      <h2 class="font-display text-xl border-b border-border pb-2">Summary</h2>
      <p class="text-primary leading-relaxed mt-4">
        Senior software engineer with 7+ years building and scaling high-traffic APIs and cloud
        platforms for SaaS products. A product-first engineer who owns critical modules end to end
        — architecture, reliability, and the internal tooling around them — turning customer pain
        points into high-impact software. Expert in Python, Django, PostgreSQL, and AWS, with
        growing full-stack range across React and TypeScript.
      </p>
    </section>

    <section class="mt-10">
      <h2 class="font-display text-xl border-b border-border pb-2">Experience</h2>
      <div class="mt-4 space-y-7">
        {
          CAREER.map((e) => (
            <div>
              <div class="flex items-baseline justify-between gap-4">
                <p class="font-medium">
                  {e.role} <span class="text-muted font-normal">· {e.company}</span>
                </p>
                <p class="font-mono text-xs text-muted shrink-0">{e.period}</p>
              </div>
              <p class="font-mono text-xs text-muted mt-0.5">{e.location}</p>
              <ul class="list-disc list-outside ml-5 mt-2 text-sm text-primary space-y-1.5 leading-relaxed">
                {e.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
              <p class="font-mono text-xs text-muted mt-2">{e.tech}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-10">
      <h2 class="font-display text-xl border-b border-border pb-2">Skills</h2>
      <div class="mt-4 space-y-3">
        {
          Object.entries(skills).map(([group, items]) => (
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-2">
              <span class="font-mono text-xs text-muted w-40 shrink-0">{group}</span>
              <ul class="flex flex-wrap gap-2">
                {items.map((i) => (
                  <li>
                    <Tag label={i} />
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-10">
      <h2 class="font-display text-xl border-b border-border pb-2">Projects</h2>
      <div class="mt-4 space-y-6">
        {
          PROJECTS.map((p) => (
            <div>
              <div class="flex items-baseline justify-between gap-4">
                <p class="font-medium">
                  {p.name} <span class="text-muted font-normal">· {p.tagline}</span>
                </p>
                <p class="font-mono text-xs text-muted shrink-0">{p.year}</p>
              </div>
              <ul class="list-disc list-outside ml-5 mt-2 text-sm text-primary space-y-1.5 leading-relaxed">
                {p.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
              <p class="mt-2 flex flex-wrap items-center gap-x-2 text-xs">
                <span class="font-mono text-muted">{p.tech}</span>
                <a href={href(`/work/${p.slug}`)} class="text-coral hover:underline shrink-0">
                  Case study →
                </a>
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-10">
      <h2 class="font-display text-xl border-b border-border pb-2">Education</h2>
      <div class="mt-4 space-y-4">
        {
          EDUCATION.map((e) => (
            <div>
              <div class="flex items-baseline justify-between gap-4">
                <p class="font-medium">{e.degree}</p>
                <p class="font-mono text-xs text-muted shrink-0">{e.period}</p>
              </div>
              <p class="text-muted text-sm mt-0.5">
                {e.institution} · {e.location}
              </p>
              <ul class="list-disc list-outside ml-5 mt-2 text-sm text-primary space-y-1">
                {e.notes.map((n) => (
                  <li>{n}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>
  </article>
</BaseLayout>
